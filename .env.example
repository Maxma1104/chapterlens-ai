# Public app URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (leave blank for local demo mode)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# OpenAI (leave blank to use the deterministic demo engine)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
OPENAI_MAX_OUTPUT_TOKENS=8000
ANALYSIS_TIMEOUT_MS=110000
# Keep pricing configurable: update these values from the current pricing page.
OPENAI_INPUT_COST_PER_MILLION=0
OPENAI_OUTPUT_COST_PER_MILLION=0

# Observability (optional)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
